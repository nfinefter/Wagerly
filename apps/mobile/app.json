{
  "expo": {
    "name": "MarketLeague",
    "slug": "marketleague",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "wagerly",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wagerly.marketleague"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.wagerly.marketleague"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
